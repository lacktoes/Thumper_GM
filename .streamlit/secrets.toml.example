# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit it.
#
# For Streamlit Community Cloud deployment:
#   Dashboard → App settings → Secrets → paste contents here.
# For Railway/Render: set these as environment variables instead.

YAHOO_CLIENT_ID     = "your_yahoo_client_id"
YAHOO_CLIENT_SECRET = "your_yahoo_client_secret"
YAHOO_REFRESH_TOKEN = "your_refresh_token"
YAHOO_LEAGUE_KEY    = "465.l.XXXXX"
TOTAL_TEAMS         = "12"
